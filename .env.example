# ── ScholarSync Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# ⚠️  Never commit .env to version control.

# Required: Groq API key for LLM generation (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Override the default backend URL used by the Streamlit frontend.
# Default is http://localhost:8000 — only change this if you deploy the backend
# somewhere else (e.g. a cloud VM or container).
# BACKEND_URL=http://localhost:8000
